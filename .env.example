# Discord
DISCORD_TOKEN=your_discord_bot_token_here

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Google Calendar (path to service account JSON)
GOOGLE_CALENDAR_CREDENTIALS=credentials/service_account.json
PROFESSOR_CALENDAR_ID=your_calendar_id@gmail.com

# Database
DATABASE_URL=sqlite+aiosqlite:///data/beiet.db

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_data

# Bot Config
BOT_PREFIX=!
DEFAULT_SUBJECT=optimizacion
LOG_LEVEL=INFO
